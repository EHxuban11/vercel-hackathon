# Supabase (M3) — via Vercel Marketplace integration or supabase.com dashboard.
# Without these the app runs in local mode (localStorage).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ElevenLabs (M2/M6) — live contextual TTS via /api/roast.
# Without it the app falls back to pre-generated mp3s, then browser speech.
ELEVENLABS_API_KEY=
# Optional: defaults to "Daniel" (deep British disappointed-dad voice)
ELEVENLABS_VOICE_ID=

# Auth0 (M4) — optional; without it the app uses nickname identity.
# Create a Regular Web App in Auth0, callback URL: {APP_BASE_URL}/auth/callback
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET= # openssl rand -hex 32
APP_BASE_URL=http://localhost:3000
